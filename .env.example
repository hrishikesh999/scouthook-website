# Vercel: Project → Settings → Environment Variables
# API key: https://resend.com/api-keys

# Neon (Postgres) — required for /api/waitlist (waitlist signups)
# Create a project at https://neon.tech and paste the connection string (sslmode=require).
DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

RESEND_API_KEY=re_xxxxxxxx

# Inbox for early-access and contact form (contact API also reads CONTACT_EMAIL_TO)
EMAIL_TO=contact@scouthook.com
# CONTACT_EMAIL_TO=contact@scouthook.com

# Sender must use your verified Resend domain (you added send.scouthook.com).
# Override if you use a different mailbox (e.g. hello@send.scouthook.com).
RESEND_FROM=Scouthook <noreply@send.scouthook.com>

# Optional: return raw Resend errors in the form (debugging only).
# RESEND_DEBUG=1

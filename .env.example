# Vercel: Project → Settings → Environment Variables
# Get an API key at https://resend.com — free tier works for testing (from onboarding@resend.dev).

RESEND_API_KEY=re_xxxxxxxx

# Recipient for early-access form submissions (default in code: contact@scouthook.com)
EMAIL_TO=contact@scouthook.com

# Sender. Use Resend’s test sender until your domain is verified in Resend:
# RESEND_FROM=Scouthook <onboarding@resend.dev>
# After verifying scouthook.com in Resend, e.g.:
# RESEND_FROM=Scouthook <noreply@scouthook.com>

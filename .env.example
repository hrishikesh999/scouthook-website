# Vercel: Project → Settings → Environment Variables
# API key: https://resend.com/api-keys

RESEND_API_KEY=re_xxxxxxxx

# Where early-access notifications are delivered
EMAIL_TO=contact@scouthook.com

# Sender must use your verified Resend domain (you added send.scouthook.com).
# Override if you use a different mailbox (e.g. hello@send.scouthook.com).
RESEND_FROM=Scouthook <noreply@send.scouthook.com>

# Optional: return raw Resend errors in the form (debugging only).
# RESEND_DEBUG=1
